datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. User
enum UserRole {
  ADMIN
  STUDENT
  FACULTY
  RECRUITER
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  passwordHash       String
  firstName          String
  lastName           String
  role               UserRole
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  student            Student?
  faculty            Faculty?
  recruiter          Recruiter?
  eventRegistrations EventRegistration[]
  feedbacks          Feedback[]
  notifications      Notification[]
  announcements      Announcement[]
  activityLogs       ActivityLog[]
  organizedEvents    Event[]             @relation("UserOrganizedEvents")

  @@index([email])
}

// 2. Department
model Department {
  id            String         @id @default(uuid())
  name          String         @unique
  code          String         @unique // e.g. CSE, ECE
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  students      Student[]
  faculty       Faculty[]
  courses       Course[]
  announcements Announcement[]
  feeStructures FeeStructure[]
}

// 3. Student
model Student {
  id                    String                 @id @default(uuid())
  userId                String                 @unique
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  rollNo                String                 @unique
  departmentId          String
  department            Department             @relation(fields: [departmentId], references: [id])
  batch                 String // e.g. 2024-2028
  cgpa                  Float                  @default(0.0)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  enrollments           Enrollment[]
  attendances           Attendance[]
  assignmentSubmissions AssignmentSubmission[]
  clubMemberships       ClubMember[]
  clubsPresided         Club[]                 @relation("ClubPresident")
  applications          Application[]
  bills                 StudentBill[]

  @@index([userId])
  @@index([departmentId])
}

// 4. Faculty
model Faculty {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  designation       String // e.g. Professor, Assistant Professor
  departmentId      String
  department        Department         @relation(fields: [departmentId], references: [id])
  officeHours       String? // e.g. Mon/Wed 2-4 PM
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  courseAssignments CourseAssignment[]

  @@index([userId])
  @@index([departmentId])
}

// 5. Course
model Course {
  id                String             @id @default(uuid())
  code              String             @unique // e.g. CS301
  title             String
  credits           Int
  departmentId      String
  department        Department         @relation(fields: [departmentId], references: [id])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  courseAssignments CourseAssignment[]
  enrollments       Enrollment[]
  attendances       Attendance[]
  assignments       Assignment[]

  @@index([code])
  @@index([departmentId])
}

// 6. CourseAssignment
model CourseAssignment {
  id           String   @id @default(uuid())
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  facultyId    String
  faculty      Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  semester     String // e.g. Fall 2026, Spring 2026
  academicYear String // e.g. 2026
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([courseId, facultyId, semester, academicYear])
  @@index([courseId])
  @@index([facultyId])
}

// 7. Enrollment
enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

model Enrollment {
  id             String           @id @default(uuid())
  studentId      String
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId       String
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  semester       String
  academicYear   String
  enrollmentDate DateTime         @default(now())
  grade          String? // e.g. A, B+, F (null if ongoing)
  attendanceRate Float            @default(0.0) // Auto-updated via DB trigger
  status         EnrollmentStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([studentId, courseId, semester, academicYear])
  @@index([studentId])
  @@index([courseId])
}

// 8. Attendance
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model Attendance {
  id        String           @id @default(uuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  date      DateTime         @db.Date
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([studentId, courseId, date])
  @@index([studentId])
  @@index([courseId])
  @@index([date])
}

// 9. Assignment
model Assignment {
  id          String                 @id @default(uuid())
  courseId    String
  course      Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String
  maxMarks    Int
  dueDate     DateTime
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  submissions AssignmentSubmission[]

  @@index([courseId])
}

// 10. AssignmentSubmission
enum SubmissionStatus {
  SUBMITTED
  GRADED
  LATE
}

model AssignmentSubmission {
  id             String           @id @default(uuid())
  assignmentId   String
  assignment     Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  submissionDate DateTime         @default(now())
  marksObtained  Float?
  feedback       String?
  fileUrl        String
  status         SubmissionStatus @default(SUBMITTED)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
}

// 11. Club
model Club {
  id          String       @id @default(uuid())
  name        String       @unique
  description String
  category    String // e.g. Tech, Cultural, Sports
  presidentId String
  president   Student      @relation("ClubPresident", fields: [presidentId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     ClubMember[]
  events      Event[]

  @@index([presidentId])
}

// 12. ClubMember
enum ClubRole {
  MEMBER
  COORDINATOR
  SECRETARY
}

model ClubMember {
  id        String   @id @default(uuid())
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  role      ClubRole @default(MEMBER)
  joinDate  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clubId, studentId])
  @@index([clubId])
  @@index([studentId])
}

// 13. Event
model Event {
  id            String              @id @default(uuid())
  title         String
  description   String
  date          DateTime            @db.Date
  time          String // e.g. "14:00"
  location      String
  clubId        String?
  club          Club?               @relation(fields: [clubId], references: [id], onDelete: SetNull)
  organizerId   String
  organizer     User                @relation("UserOrganizedEvents", fields: [organizerId], references: [id])
  capacity      Int
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  registrations EventRegistration[]

  @@index([clubId])
  @@index([organizerId])
}

// 14. EventRegistration
enum RegistrationStatus {
  REGISTERED
  ATTENDED
  CANCELLED
}

model EventRegistration {
  id               String             @id @default(uuid())
  eventId          String
  event            Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  registrationDate DateTime           @default(now())
  status           RegistrationStatus @default(REGISTERED)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

// 15. Company
model Company {
  id          String       @id @default(uuid())
  name        String       @unique
  industry    String
  website     String?
  description String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  recruiters  Recruiter[]
  internships Internship[]
}

// 16. Recruiter
model Recruiter {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  designation String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
}

// 17. Internship
model Internship {
  id              String        @id @default(uuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title           String
  description     String
  location        String
  type            String // e.g. "Full-time", "Part-time", "Remote"
  stipend         Float
  stipendCurrency String        @default("INR")
  durationMonths  Int
  deadline        DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  applications    Application[]

  @@index([companyId])
}

// 18. Application
enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFERED
  REJECTED
}

model Application {
  id              String                     @id @default(uuid())
  internshipId    String
  internship      Internship                 @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  studentId       String
  student         Student                    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  applicationDate DateTime                   @default(now())
  resumeUrl       String
  coverLetter     String?
  status          ApplicationStatus          @default(APPLIED)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  statusHistory   ApplicationStatusHistory[]

  @@unique([internshipId, studentId])
  @@index([internshipId])
  @@index([studentId])
}

// 19. ApplicationStatusHistory
model ApplicationStatusHistory {
  id            String            @id @default(uuid())
  applicationId String
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  status        ApplicationStatus
  changedById   String?
  changedAt     DateTime          @default(now())

  @@index([applicationId])
}

// 20. Feedback
enum FeedbackCategory {
  ACADEMIC
  INFRASTRUCTURE
  SERVICES
  GENERAL
}

model Feedback {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       FeedbackCategory
  rating         Int // 1 to 5 scale
  comments       String
  submissionDate DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([userId])
}

// 21. Notification
enum NotificationType {
  ACADEMIC
  EVENT
  PLACEMENT
  ALERT
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean          @default(false)
  type      NotificationType
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
}

// 22. Announcement
enum AnnouncementTarget {
  ALL
  STUDENTS
  FACULTY
  DEPARTMENT
}

model Announcement {
  id           String             @id @default(uuid())
  title        String
  content      String
  type         AnnouncementTarget @default(ALL)
  departmentId String?
  department   Department?        @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  creatorId    String
  creator      User               @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([departmentId])
  @@index([creatorId])
}

// 23. ActivityLog
model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// 24. FeeStructure
model FeeStructure {
  id           String        @id @default(uuid())
  title        String
  amount       Float
  dueDate      DateTime
  departmentId String?
  department   Department?   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  batch        String? // Optional, if it applies to a specific batch e.g. "2024-2028"
  academicYear String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  bills        StudentBill[]

  @@index([departmentId])
}

// 25. StudentBill
enum BillStatus {
  PENDING
  PAID
  OVERDUE
}

model StudentBill {
  id             String       @id @default(uuid())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  amount         Float
  status         BillStatus   @default(PENDING)
  dueDate        DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  payments       Payment[]

  @@index([studentId])
  @@index([feeStructureId])
}

// 26. Payment
enum PaymentStatus {
  SUCCESS
  FAILED
}

model Payment {
  id            String        @id @default(uuid())
  studentBillId String
  studentBill   StudentBill   @relation(fields: [studentBillId], references: [id], onDelete: Cascade)
  amountPaid    Float
  paymentDate   DateTime      @default(now())
  transactionId String?       @unique
  status        PaymentStatus @default(SUCCESS)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([studentBillId])
}
